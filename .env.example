# ============================================================
# Self-Service Provisioning — configuration
# Copy to ".env" and fill in. Leave a section blank to keep that
# part simulated. The app runs end-to-end even with NOTHING set.
# ============================================================

# ---- 1) Azure OpenAI : enables REAL grounded planning + RAG ----
# Pre-filled for this demo's resource — the ONLY thing you must add is the key
# (Azure portal -> your OpenAI/Foundry resource -> Keys & Endpoint).
AZURE_OPENAI_ENDPOINT=https://jiyan-m85rcjnj-eastus2.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBED_API_VERSION=2024-10-21
# The *deployment names* as created in the resource.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002
# 'responses' for gpt-5.x reasoning models; 'chat' for gpt-4o-mini; 'auto' tries both.
AZURE_OPENAI_API_STYLE=responses
# Optional reasoning effort (blank = model default; some 'pro' models need 'medium'/'high').
AZURE_OPENAI_REASONING_EFFORT=
AZURE_OPENAI_MAX_OUTPUT_TOKENS=4096

# ---- 2) Deploy target ----
# SIMULATE_DEPLOY=true => semi-simulation: real RAG + LLM, but the deploy + CMDB
# are simulated with realistic IDs (no privileged identity needed; anyone can run
# it). Set false to deploy for real (then auth in section 3 is used).
SIMULATE_DEPLOY=true
# Used for real deploys, and to make simulated resource IDs look authentic.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-selfservice-lz
AZURE_LOCATION=westus2

# ---- 3) Auth for the deploy target ----
# Option A: a service principal scoped Contributor on the RG (fill all three).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Option B (no app-registration rights?): leave the three above blank and the
# app signs in as YOU — it reuses an `az login` / Azure PowerShell session if
# present, otherwise prompts interactively.
#   AZURE_AUTH_FLOW=auto    -> browser sign-in popup (default)
#   AZURE_AUTH_FLOW=device  -> device-code (shows a code + URL; best behind proxies)
AZURE_AUTH_FLOW=auto

# ---- Auto-delete (TTL) ----
# Provisioned resources are automatically deleted this many minutes after deploy
# (works in both semi-simulation and real mode). Users can "Extend" up to MAX.
RESOURCE_TTL_MINUTES=120
MAX_TTL_MINUTES=1440
JANITOR_INTERVAL_SECONDS=120
JANITOR_ENABLED=true

# ---- Display only ----
LANDING_ZONE_NAME=lz-sandbox-01

# The chat help assistant reuses AZURE_OPENAI_* above (no extra config).
